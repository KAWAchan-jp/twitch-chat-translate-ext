{
  "manifest_version": 3,
  "name": "Twitch Chat Translator",
  "version": "0.5.6.0",
  "description": "Twitchチャットをリアルタイム日本語翻訳",

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },

  "permissions": [
    "storage",
    "contextMenus",
    "tabs"
  ],

  "host_permissions": [
    "https://translate.googleapis.com/*",
    "https://api.deepl.com/*",
    "https://api-free.deepl.com/*",
    "https://api.twitch.tv/*",
    "https://id.twitch.tv/*",
    "https://api.groq.com/*",
    "https://huggingface.co/*",
    "https://cdn-lfs.huggingface.co/*",
    "https://cdn-lfs-us-1.huggingface.co/*",
    "https://cas-bridge.xethub.hf.co/*",
    "https://cdn.jsdelivr.net/*",
    "https://generativelanguage.googleapis.com/*"
  ],

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "background": {
    "service_worker": "background.js"
  },

  "web_accessible_resources": [{
    "resources": [
      "whisper-worker.js",
      "lib/transformers.min.js",
      "lib/ort-wasm-simd-threaded.jsep.wasm",
      "lib/ort-wasm-simd-threaded.jsep.mjs",
      "lib/ort-wasm-simd.wasm",
      "lib/ort-wasm.wasm"
    ],
    "matches": ["*://www.twitch.tv/*"]
  }],

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Twitch Chat Translator（クリックで表示切替）"
  },

  "content_scripts": [
    {
      "matches": ["*://www.twitch.tv/*"],
      "js": ["content-panel.js", "content-chat.js", "content-whisper.js", "content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://kawachan-jp.github.io/twitch-chat-translate/*"],
      "js": ["auth-callback.js"],
      "run_at": "document_start"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
