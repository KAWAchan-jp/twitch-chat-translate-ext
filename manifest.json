{
  "manifest_version": 3,
  "name": "Twitch Chat Translator",
  "version": "0.3.0",
  "description": "Twitchチャットをリアルタイム日本語翻訳",

  "permissions": [
    "storage",
    "contextMenus",
    "tabs"
  ],

  "host_permissions": [
    "https://translate.googleapis.com/*",
    "https://api.twitch.tv/*",
    "https://id.twitch.tv/*",
    "https://api.groq.com/*",
    "https://huggingface.co/*",
    "https://cdn-lfs.huggingface.co/*",
    "https://cdn-lfs-us-1.huggingface.co/*",
    "https://cdn.jsdelivr.net/*"
  ],

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Twitch Chat Translator（クリックで表示切替）"
  },

  "content_scripts": [
    {
      "matches": ["*://www.twitch.tv/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://kawachan-jp.github.io/twitch-chat-translate/*"],
      "js": ["auth-callback.js"],
      "run_at": "document_start"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
