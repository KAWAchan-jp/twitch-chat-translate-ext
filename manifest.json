{
  "manifest_version": 3,
  "name": "Twitch Chat Translator",
  "version": "0.9.0",
  "description": "Twitchチャットをリアルタイム日本語翻訳",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://translate.googleapis.com/*",
    "https://api.twitch.tv/*",
    "https://id.twitch.tv/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
